    <div class="fade-in mt-16 grid gap-12 md:grid-cols-2">
      <!-- Contact details -->
      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-medium uppercase tracking-wider text-accent-warm">
            Telefon
          </h3>
          <a
            href="tel:+48693405963"
            class="mt-1 block text-lg font-light text-foreground transition-colors hover:text-accent-warm"
          >
            693 405 963
          </a>
        </div>

        <div>
          <h3 class="text-sm font-medium uppercase tracking-wider text-accent-warm">
