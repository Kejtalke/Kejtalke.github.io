---
const BOOKSY_URL =
  'https://booksy.com/pl-pl/328910_strefa-zmian_salon-kosmetyczny_15608_poznan';

const DAY_NAMES: Record<number, string> = {
  1: 'Poniedziałek',
  2: 'Wtorek',
  3: 'Środa',
  4: 'Czwartek',
  5: 'Piątek',
  6: 'Sobota',
  7: 'Niedziela',
};

interface OpenHourSlot {
  open_from: string;
  open_till: string;
  day_of_week: number;
}

const FALLBACK_HOURS = [
  { day: 'Poniedziałek', time: '09:00 – 15:30' },
  { day: 'Wtorek', time: '16:15 – 19:00' },
  { day: 'Środa', time: '10:00 – 19:00' },
  { day: 'Czwartek', time: '10:00 – 19:00' },
  { day: 'Piątek', time: '10:00 – 19:00' },
  { day: 'Sobota', time: '07:00 – 19:00' },
  { day: 'Niedziela', time: '10:00 – 13:30' },
];

let hours = FALLBACK_HOURS;

try {
  const res = await fetch(BOOKSY_URL, {
    headers: { 'User-Agent': 'Mozilla/5.0 (compatible; AstroSSG/1.0)' },
  });
  const html = await res.text();

  // Extract open_hours array from window.__NUXT__ payload
  const match = html.match(/"open_hours"\s*:\s*(\[[\s\S]*?\])\s*[,}]/);
  if (match) {
    const slots: OpenHourSlot[] = JSON.parse(match[1]);

    // Group slots by day_of_week
    const grouped = new Map<number, OpenHourSlot[]>();
    for (const slot of slots) {
      // Skip zero-length slots (e.g. 13:30–13:30)
      if (slot.open_from === slot.open_till) continue;
      const existing = grouped.get(slot.day_of_week) ?? [];
      existing.push(slot);
      grouped.set(slot.day_of_week, existing);
    }

    const parsed = [];
    for (let d = 1; d <= 7; d++) {
      const daySlots = grouped.get(d);
      if (!daySlots || daySlots.length === 0) {
        parsed.push({ day: DAY_NAMES[d], time: 'Zamknięte' });
        continue;
      }
      // Sort by open_from and join ranges
      daySlots.sort((a, b) => a.open_from.localeCompare(b.open_from));
      const ranges = daySlots.map((s) => `${s.open_from} – ${s.open_till}`);
      parsed.push({ day: DAY_NAMES[d], time: ranges.join(', ') });
    }

    hours = parsed;
  }
} catch {
  // Fetch failed — use fallback hours
}
