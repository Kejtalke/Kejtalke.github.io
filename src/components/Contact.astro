---
---

<section id="kontakt" class="bg-background py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="fade-in text-center">
      <p class="section-label">Kontakt</p>
      <h2
        class="mt-3 font-heading text-3xl font-light text-foreground md:text-4xl"
      >
        Umów się na wizytę
      </h2>

      <p class="mx-auto mt-4 max-w-md text-sm font-light leading-relaxed text-muted">
        Chcesz zadbać o swoje paznokcie, rzęsy lub brwi? Zarezerwuj wygodny termin online - szybko i bez dzwonienia.
      </p>

      <a
        href="https://booksy.com/pl-pl/328910_strefa-zmian_salon-kosmetyczny_15608_poznan"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-8"
      >
        Rezerwuj przez Booksy
        <span class="sr-only">(otwiera nową kartę)</span>
      </a>
    </div>

    <div class="fade-in mt-16 grid gap-8 md:grid-cols-3">
      <!-- Contact details -->
      <div class="md:col-span-3 grid gap-4 md:grid-cols-3">
        <div class="group rounded-xl border border-border bg-surface/50 p-5 transition-all duration-300 hover:border-accent-warm/20 hover:shadow-sm">
          <h3 class="flex items-center gap-2.5 text-sm font-medium uppercase tracking-wider text-accent-warm">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Telefon
          </h3>
          <a
            href="tel:+48693405963"
            class="mt-2 block text-lg font-light text-foreground transition-colors hover:text-accent-warm"
          >
            693 405 963
          </a>
        </div>

        <div class="group rounded-xl border border-border bg-surface/50 p-5 transition-all duration-300 hover:border-accent-warm/20 hover:shadow-sm">
          <h3 class="flex items-center gap-2.5 text-sm font-medium uppercase tracking-wider text-accent-warm">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </h3>
          <a
            href="mailto:strefazmianpoznan@gmail.com"
            class="mt-2 block text-lg font-light text-foreground transition-colors hover:text-accent-warm"
          >
            strefazmianpoznan@gmail.com
          </a>
        </div>

        <div class="group rounded-xl border border-border bg-surface/50 p-5 transition-all duration-300 hover:border-accent-warm/20 hover:shadow-sm">
          <h3 class="flex items-center gap-2.5 text-sm font-medium uppercase tracking-wider text-accent-warm">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Adres
          </h3>
          <p class="mt-2 text-lg font-light text-foreground">
            Sieradzka 24 / Lokal Nr 3
          </p>
          <p class="text-sm font-light text-muted">
            60-163 Poznań, Grunwald (wejście z boku bloku)
          </p>
        </div>
      </div>
    </div>

    <!-- Google Maps embed -->
    <div class="fade-in mt-16 overflow-hidden rounded-2xl border border-border">
      <iframe
        title="Lokalizacja Strefa Zmian"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2434.2!2d16.876!3d52.424!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sSieradzka+24%2C+60-163+Pozna%C5%84!5e0!3m2!1spl!2spl!4v1"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>
