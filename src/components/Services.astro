---
const services = [
  {
    name: 'Stylizacja paznokci',
    description: 'Manicure hybrydowy, przedłużanie żelem, zdobienia - trwałe i piękne paznokcie.',
    price: 'od 100 zł',
  },
  {
    name: 'Stylizacja rzęs',
    description: 'Przedłużanie rzęs metodą 1:1, objętościową i laminacja dla naturalnego efektu.',
    price: 'od 140 zł',
  },
  {
    name: 'Stylizacja brwi',
    description: 'Laminacja, henna pudrowa i regulacja - idealna oprawa oczu.',
    price: 'od 40 zł',
  },
  {
    name: 'Pedicure',
    description: 'Pedicure kosmetyczny z dbałością o każdy detal, zdrowe i zadbane stopy.',
    price: 'od 60 zł',
  },
];
---

<section id="uslugi" class="bg-background py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="fade-in text-center">
      <p class="section-label">Usługi</p>
      <h2
        class="mt-3 font-heading text-3xl font-light text-foreground md:text-4xl"
      >
        Czym się zajmuję
      </h2>
    </div>

    <div
      class="fade-in-children mt-16 grid gap-6 sm:grid-cols-2"
    >
      {
        services.map((service) => (
          <div class="rounded-2xl border border-border bg-background p-8 transition-shadow hover:shadow-md">
            <h3 class="font-heading text-xl font-normal text-foreground md:text-2xl">
              {service.name}
            </h3>
            <p class="mt-3 text-sm font-light leading-relaxed text-muted">
              {service.description}
            </p>
            <p class="mt-4 text-sm font-medium text-accent-warm">
              {service.price}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
