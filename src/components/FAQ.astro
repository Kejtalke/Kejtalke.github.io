---
const faqs = [
  {
    question: 'Jak długo trzyma manicure hybrydowy?',
    answer:
      'Manicure hybrydowy wykonany w Strefie Zmian utrzymuje się średnio od 2 do 3 tygodni. Trwałość zależy od indywidualnych predyspozycji płytki paznokcia oraz codziennej pielęgnacji dłoni.',
  },
  {
    question: 'Jak przygotować się do przedłużania rzęs?',
    answer:
      'Przed wizytą unikaj tuszu do rzęs i olejowych kosmetyków wokół oczu. Przyjdź z czystymi, odtłuszczonymi rzęsami — dzięki temu klej lepiej się wiąże i efekt utrzymuje się dłużej.',
  },
  {
    question: 'Czy laminacja brwi jest bezpieczna?',
    answer:
      'Tak, laminacja brwi to bezpieczny zabieg, o ile wykonywany jest przez doświadczonego stylistę z użyciem sprawdzonych preparatów. W Strefie Zmian stosuję produkty dermatologicznie testowane.',
  },
  {
    question: 'Jak dojechać do salonu na Grunwaldzie?',
    answer:
      'Salon Strefa Zmian znajduje się przy ul. Sieradzkiej 24 (lokal nr 3) na poznańskim Grunwaldzie. Wejście z boku bloku. W pobliżu znajdują się przystanki komunikacji miejskiej oraz miejsca parkingowe.',
  },
  {
    question: 'Jak umówić się na wizytę?',
    answer:
      'Najwygodniej zarezerwować termin online przez Booksy — wystarczy kilka kliknięć. Możesz też zadzwonić pod numer 693 405 963 lub napisać e-mail.',
  },
  {
    question: 'Czy mogę odwołać lub przełożyć wizytę?',
    answer:
      'Tak, wizytę możesz odwołać lub przełożyć bezpłatnie z odpowiednim wyprzedzeniem przez aplikację Booksy lub kontaktując się ze mną telefonicznie.',
  },
];
---

<section id="faq" class="bg-background py-24 md:py-32">
  <div class="mx-auto max-w-3xl px-6">
    <div class="fade-in text-center">
      <p class="section-label">FAQ</p>
      <h2
        class="mt-3 font-heading text-3xl font-light text-foreground md:text-4xl"
      >
        Najczęściej zadawane pytania
      </h2>
    </div>

    <div class="fade-in mt-16 space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl border border-border bg-background transition-all duration-300 hover:border-accent-warm/20 hover:shadow-md hover:shadow-accent-warm/5">
            <summary class="flex cursor-pointer list-none items-center justify-between p-6 font-heading text-base font-normal text-foreground md:text-lg [&::-webkit-details-marker]:hidden">
              {faq.question}
              <span class="ml-4 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border border-border text-accent-warm transition-all duration-300 group-open:rotate-180 group-open:border-accent-warm/30 group-open:bg-accent-warm/5">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 4.5l3 3 3-3"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer">
              <div>
                <div class="border-t border-border px-6 pb-6 pt-4">
                  <p class="text-sm font-light leading-relaxed text-muted">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
