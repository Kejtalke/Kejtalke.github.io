---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { services, BOOKSY_URL } from '../data/services';
---

<Layout
  title="Usługi - Strefa Zmian Poznań"
  description="Szczegółowy opis usług w Strefie Zmian: stylizacja rzęs, paznokci, brwi oraz pedicure kosmetyczny i podologiczny."
>
  <main id="main-content">
    <section class="bg-background pb-16 pt-28 md:pt-32">
      <div class="mx-auto max-w-3xl px-6">
        <div class="fade-in text-center">
          <p class="section-label">Usługi</p>
          <h1 class="mt-3 font-heading text-3xl font-light text-foreground md:text-4xl">
            Szczegóły zabiegów
          </h1>
          <p class="mx-auto mt-4 max-w-xl text-sm font-light leading-relaxed text-muted">
            Pracuję holistycznie - dbam nie tylko o efekt wizualny, ale też o komfort, bezpieczeństwo i zdrowie naturalnych rzęs, paznokci oraz skóry.
          </p>
        </div>
      </div>
    </section>

    {services.map((service, index) => (
      <>
        <section id={service.slug} class="bg-background py-16 md:py-20">
          <div class="mx-auto max-w-3xl px-6">
            <div class="fade-in">
              <div class="mb-6 flex items-center gap-4">
                <div class="text-accent-warm/70">
                  <Fragment set:html={service.icon} />
                </div>
                <h2 class="font-heading text-2xl font-light text-foreground md:text-3xl">
                  {service.name}
                </h2>
              </div>

              <p class="text-sm font-light leading-relaxed text-muted">
                {service.description}
              </p>

              {service.image && (
                <div class="mt-6 overflow-hidden rounded-xl">
                  <img
                    src={service.image}
                    alt={service.name}
                    loading="lazy"
                    class="h-56 w-full object-cover"
                  />
                </div>
              )}

              {/* Treatments */}
              <div class="mt-8">
                <p class="mb-4 text-xs font-medium uppercase tracking-wider text-accent-warm">Zabiegi</p>
                <div class="space-y-4">
                  {service.details.treatments.map((t: { name: string; description: string }) => (
                    <div class="rounded-xl border border-border/60 bg-surface/30 p-5">
                      <p class="font-heading text-base font-normal text-foreground">{t.name}</p>
                      <p class="mt-2 text-sm font-light leading-relaxed text-muted">{t.description}</p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Contraindications */}
              <div class="mt-8">
                <p class="mb-3 text-xs font-medium uppercase tracking-wider text-accent-warm">Przeciwwskazania</p>
                <ul class="space-y-2">
                  {service.details.contraindications.map((c: string) => (
                    <li class="flex items-start gap-2 text-sm font-light text-muted">
                      <svg class="mt-0.5 h-3.5 w-3.5 flex-shrink-0 text-accent-warm/40" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <circle cx="8" cy="8" r="7" />
                        <path d="M10 6L6 10M6 6l4 4" />
                      </svg>
                      {c}
                    </li>
                  ))}
                </ul>
              </div>

              {/* CTA */}
              <div class="mt-8">
                <a
                  href={BOOKSY_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-medium tracking-wide text-accent-warm transition-all duration-200 hover:gap-2.5"
                >
                  Umów wizytę
                  <span class="sr-only">(otwiera nową kartę)</span>
                  <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2.5 6h7M6.5 3l3 3-3 3"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </section>

        {index < services.length - 1 && (
          <div class="bg-background py-2">
            <div class="ornament" aria-hidden="true">
              <span class="ornament-diamond"></span>
            </div>
          </div>
        )}
      </>
    ))}
  </main>
  <Footer />
</Layout>
